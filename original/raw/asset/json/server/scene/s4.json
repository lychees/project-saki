            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>整个学校里这个时候只有我们实验班\n</span><span style='color:#FfFffF'>和准高一参加奥运汇演排练的新生。\n</span><span style='color:#FfFffF'>我们打开一间间平时不会去访问的教室。\n</span><span style='color:#FfFffF'>直到累了之后，伏在顶楼的栏杆上。</span>",
