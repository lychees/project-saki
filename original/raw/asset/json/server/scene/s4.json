            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>呐，你说，月亮上会有生命么？</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65932106179_0.9643098285153189"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>嗯哼...\n</span><span style='color:#FfFffF'>根据目前的观测结果...太阳系的其他行星里都没有类地生命的存在呢。</span>",
                null,
                1,
                0,
                {
                    "___cmdID": "65932137348_0.7730272725147271"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>但是不排除会有简单的单细胞生命存在吧？</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65932181628_0.04966629775363396"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>额，确实。目前的实验数据都没有能够证实或证伪 ...</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65932203669_0.0061956268751914845"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>没有证伪... 也就是说还是有可能存在的吧？\n</span><span style='color:#FfFffF'>也许在月之暗面，也许在月面的岩层之下？\n</span><span style='color:#FfFffF'>生活着我们未曾发现过的厌氧细胞。</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65932239520_0.8609960147327567"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>呃，不能排除这种可能性存在。</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65932263992_0.32277566751818143"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>那你说，我们生活的宇宙中，\n</span><span style='color:#FfFffF'>会有其他的 ... 宇宙人存在吗？</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65932283351_0.5365384665735673"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>这个...</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65958021042_0.8162160921890751"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>目前...还没有观测到宇宙人存在的迹象...\n</span><span style='color:#FfFffF'>而且要构成生命存在所需要的基本条件，\n</span><span style='color:#FfFffF'>大气，温度，自转等等，\n</span><span style='color:#FfFffF'>每一件都是一件极小概率的事件。。。</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65932305706_0.5641340738871772"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>可是「地球」恰好就是一颗这样的行星啊，\n</span><span style='color:#FfFffF'>这样看的话宇宙存在像地球这样的星球，\n</span><span style='color:#FfFffF'>也会是很自然的事情吧。</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65958108768_0.7904963643469631"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>你说的现象是「幸存者偏差」而已，\n</span><span style='color:#FfFffF'>只是因为你恰好生活在「地球」之上。。。</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65964070582_0.44795860805708076"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>如果地日距离缩小千分之一的话，\n</span><span style='color:#FfFffF'>地球上所有的生命就会因炎热而死；\n</span><span style='color:#FfFffF'>如果地日距离扩大千分之一的话，\n</span><span style='color:#FfFffF'>地球上所有的生命就会因寒冷而死。</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65958127103_0.17249748568496925"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>可是生命需要水，需要氧气，也只是基于人类目前\n</span><span style='color:#FfFffF'>所观察到的结果所做的假设而已。也许 ...\n</span><span style='color:#FfFffF'>在遥远的外太空，居住着比我们还要聪明的，\n</span><span style='color:#FfFffF'>可以呼吸二氧化硫的非碳基生命呢。</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65958154730_0.1700828171754889"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>呃...</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65958189850_0.5487680192349493"
                }
            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>被连珠炮似地提问，似乎是一时间想不到如何回答\n</span><span style='color:#FfFffF'>MoonMayCry 抬起头，望向了远处的深空</span>",
                null,
                1,
                0,
                {
                    "___cmdID": "65932324766_0.8969692809482035"
                }
            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>（忽明忽现的星光将原本漆黑的夜幕点缀的生机盎然。）</span>",
                null,
                1,
                0,
                {
                    "___cmdID": "65932382440_0.5584255640349365"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>我想应该存在吧，毕竟宇宙的尺度那么大。\n</span><span style='color:#FfFffF'>可观测的宇宙只占空间的很小一部分。\n</span><span style='color:#FfFffF'>无限小的概率在无限大的样本空间里\n</span><span style='color:#FfFffF'>也会成为必然事件。</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65932405581_0.4034040887945256"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>是啊... 如果诺大的宇宙中，只有我们人类，\n</span><span style='color:#FfFffF'>那我们... 岂不是...\n</span><span style='color:#FfFffF'>太孤单了吗？</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65932464372_0.8604020215370198"
                }
            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>MoonMayCry叹息了一下</span>",
                null,
                1,
                0,
                {
                    "___cmdID": "65963160026_0.7472490496771358"
                }
            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>Kotori 伸出手，指向遥远的深空。</span>",
                null,
                1,
                0,
                {
                    "___cmdID": "65958296334_0.6301076253998754"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>你看，在那颗星星的方向上，此时此刻\n</span><span style='color:#FfFffF'>是不是也会有另一个人，也在和我思考着相同的问题呢。</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65958385006_0.5611147426017045"
                }
            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>星光闪烁，仿佛在无言地回答</span>",
                null,
                1,
                0,
                {
                    "___cmdID": "65958404233_0.6599355527926014"
                }
            ],
            [
                11,
                3,
                4,
                "MoonMayCry",
                3,
                -3,
                "<span style='color:#FfFffF'>...</span>",
                null,
                2,
                0,
                {
                    "___cmdID": "65958315404_0.15678061611006577"
                }
            ],
            [
                11,
                3,
                2,
                "Kotori",
                3,
                -3,
                "<span style='color:#FfFffF'>...</span>",
                null,
                14,
                0,
                {
                    "___cmdID": "65958327881_0.7386082372007661"
                }
            ],
            [
                11,
                3,
                null,
                "",
                3,
                -3,
                "<span style='color:#FfFffF'>两人都沉默下来，无言的看向深空。\n</span><span style='color:#FfFffF'>唯有点点星光闪烁。</span>",
                null,
                1,
